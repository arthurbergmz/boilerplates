{
  "name": "{{app-name}}",
  "version": "{{app-version}}",
  "description": "{{app-description}}",
  "type": "module",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+{{repository-url}}.git"
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite dev",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt ./src --check",
    "fmt:fix": "oxfmt ./src --write",
    "check": "npm run lint && npm run fmt && npm run test",
    "prepare": "husky"
  },
  "imports": {
    "#*": "./*"
  },
  "devDependencies": {
    "@types/node": "latest",
    "@types/web": "latest",
    "@typescript/native-preview": "latest",
    "husky": "latest",
    "oxfmt": "latest",
    "oxlint": "latest",
    "oxlint-tsgolint": "latest",
    "typescript": "latest",
    "nitro": "latest",
    "vite": "latest",
    "vitest": "latest"
  },
  "engines": {
    "node": ">=24.14.1"
  },
  "packageManager": "npm@11.12.1"
}
